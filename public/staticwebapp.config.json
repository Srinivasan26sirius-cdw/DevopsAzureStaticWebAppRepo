{
  "navigationFallback": {
    "rewrite": "/index.html"
  },
  "mimeTypes": {
    ".json": "application/json",
    ".wasm": "application/wasm"
  },
  "routes": [
    {
      "route": "/assets/*",
      "statusCode": 200
    },
    {
      "route": "*.{svg,png,jpg,jpeg,gif,ico,webp,css,js}",
      "statusCode": 200
    }
  ]
}
